<?xml version="1.0" encoding="utf-8"?>
<Container version="2">
  <Name>HomELabPortal - Private (Basic Auth)</Name>
  <Repository>auskento/homelabportal:latest</Repository>
  <Registry>https://hub.docker.com/</Registry>
  <Network>bridge</Network>
  <MyIP/>
  <Shell>bash</Shell>
  <Privileged>false</Privileged>
  <Support>https://github.com/auskento/HomELabPortal</Support>
  <Project>https://github.com/auskento/HomELabPortal</Project>
  <Category>Network:Web</Category>
  <TemplateURL>https://raw.githubusercontent.com/auskento/HomELabPortal/main/homelabportal-private-basic.xml</TemplateURL>
  <Icon>https://raw.githubusercontent.com/auskento/HomELabPortal/main/homelabportal-150.png</Icon>
  <PostArgs/>
  <CloudSync>false</CloudSync>
  <Description>HomELabPortal - Private Mode with Basic Authentication. Internal-only deployment with HTTP (no SSL), protected by username/password authentication.</Description>
  <Overview>HomELabPortal - Private Deployment with Basic Auth&#13;&#13;This template is pre-configured for:&#13;- Private mode: Internal-only access on HTTP&#13;- Basic authentication with username/password&#13;- No SSL certificates or Let's Encrypt needed&#13;- Direct IP address access (e.g., http://192.168.x.x)&#13;&#13;Required settings:&#13;1. IP: Container IP address on your network&#13;2. BASIC_AUTH_CREDENTIALS: Username and password (format: user:pass)&#13;3. Service URLs: Configure your backend service URLs&#13;&#13;Optional settings:&#13;- STYLE: Dashboard style (classic, modern, sleek, minimal)&#13;- DASHBOARD_NAME, DASHBOARD_ICON, DASHBOARD_LANDING&#13;- Service enable/disable flags&#13;&#13;Documentation: https://github.com/auskento/HomELabPortal</Overview>
  <Networking>
    <Mode>br0</Mode>
    <Publish>
      <Port>
        <HostPort>80</HostPort>
        <ContainerPort>80</ContainerPort>
        <Protocol>tcp</Protocol>
        <Description>HTTP</Description>
        <Access>External</Access>
      </Port>
    </Publish>
  </Networking>
  <Data>
    <Volume>
      <HostDir>/mnt/user/appdata/homelabportal-private/logs</HostDir>
      <ContainerDir>/var/log/apache2</ContainerDir>
      <Mode>rw</Mode>
      <Description>Apache Logs</Description>
      <Access>rw</Access>
      <Exclude/>
      <IsFileShare>false</IsFileShare>
    </Volume>
  </Data>

  <Environment>
    <Variable>
      <Name>ACCESS_MODE</Name>
      <Value>private</Value>
    </Variable>
    <Variable>
      <Name>IP</Name>
      <Value>192.168.x.x</Value>
    </Variable>
    <Variable>
      <Name>TZ</Name>
      <Value>Australia/Melbourne</Value>
    </Variable>
    <Variable>
      <Name>STYLE</Name>
      <Value>sleek</Value>
    </Variable>
    <Variable>
      <Name>DASHBOARD_NAME</Name>
      <Value>Media Server</Value>
    </Variable>
    <Variable>
      <Name>DASHBOARD_ICON</Name>
      <Value>/icons/homelabportal.png</Value>
    </Variable>
    <Variable>
      <Name>DASHBOARD_LANDING</Name>
      <Value></Value>
    </Variable>
    <Variable>
      <Name>DASHBOARD_ORDER</Name>
      <Value>CONTENT,SEARCH,USENET,TORRENTS,MEDIA</Value>
    </Variable>
    <Variable>
      <Name>DASHBOARD_THEME</Name>
      <Value>dark</Value>
    </Variable>
    <Variable>
      <Name>AUTHTYPE</Name>
      <Value>basic</Value>
    </Variable>
    <Variable>
      <Name>BASIC_AUTH_CREDENTIALS</Name>
      <Value>user:password</Value>
    </Variable>
    <!-- USENET Services -->
    <Variable>
      <Name>ENABLE_SABNZBD</Name>
      <Value>false</Value>
    </Variable>
    <Variable>
      <Name>SABNZBD_URL</Name>
      <Value>http://YOUR_BACKEND_HOST:8080/sabnzbd</Value>
    </Variable>
    <Variable>
      <Name>ENABLE_NZBGET</Name>
      <Value>false</Value>
    </Variable>
    <Variable>
      <Name>NZBGET_URL</Name>
      <Value>http://YOUR_BACKEND_HOST:6789/nzbget</Value>
    </Variable>
    <Variable>
      <Name>NZBGET_USER</Name>
      <Value></Value>
    </Variable>
    <Variable>
      <Name>NZBGET_PASS</Name>
      <Value></Value>
    </Variable>
    <Variable>
      <Name>ENABLE_NZBHYDRA</Name>
      <Value>false</Value>
    </Variable>
    <Variable>
      <Name>NZBHYDRA_URL</Name>
      <Value>http://YOUR_BACKEND_HOST:5076/nzbhydra</Value>
