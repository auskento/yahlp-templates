  <Config Name="Dashboard Name" Target="DASHBOARD_NAME" Default="Media Server" Mode="" Description="Title displayed in dashboard" Type="Variable" Display="always" Required="false" Mask="false"/>
  <Config Name="Dashboard Icon URL" Target="DASHBOARD_ICON_URL" Default="" Mode="" Description="URL to download custom dashboard icon (optional - downloaded and cached like service icons). If provided, overrides DASHBOARD_ICON path" Type="Variable" Display="always" Required="false" Mask="false"/>
  <Config Name="Dashboard Theme" Target="DASHBOARD_THEME" Default="dark" Mode="" Description="Choose: dark or light" Type="Variable" Display="always" Required="false" Mask="false"/>
  <Config Name="Dashboard Landing Page" Target="DASHBOARD_LANDING" Default="" Mode="" Description="Default page to load when accessing dashboard. Examples: radarr, sonarr, sonarr/calendar, radarr/upcoming. Leave blank to show welcome screen." Type="Variable" Display="always" Required="false" Mask="false"/>
  <Config Name="Dashboard Category Order" Target="DASHBOARD_ORDER" Default="CONTENT,SEARCH,USENET,TORRENTS,MEDIA" Mode="" Description="Comma-separated category display order" Type="Variable" Display="always" Required="false" Mask="false"/>
