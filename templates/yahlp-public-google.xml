<?xml version="1.0" encoding="utf-8"?>
<Container version="2">
  <Name>YAHLP-GoogleOAuth</Name>
  <Repository>auskento/yahlp</Repository>
  <Registry>https://hub.docker.com</Registry>
  <Network>bridge</Network>
  <MyIP/>
  <Shell>bash</Shell>
  <Privileged>false</Privileged>
  <Support>https://github.com/auskento/YAHLP</Support>
  <Project>https://github.com/auskento/YAHLP</Project>
  <Category>Network:Web</Category>
  <TemplateURL>https://raw.githubusercontent.com/auskento/yahlp-templates/main/templates/yahlp-public-google.xml</TemplateURL>
  <Icon>https://raw.githubusercontent.com/auskento/YAHLP/main/html/icons/yahlp.png</Icon>
  <WebUI>https://[IP]:[PORT:443]/</WebUI>
  <CloudSync>false</CloudSync>
  <Description>YAHLP - Public Mode with Google OAuth. HTTPS via Let's Encrypt + Google login authentication for internet-facing deployments.</Description>
  <Overview>YAHLP - Yet Another HomeLab Portal - Public Mode with Google OAuth

Configured for public internet deployment with:
- HTTPS with automatic Let's Encrypt certificates
- Google OAuth 2.0 authentication
- Requires domain name and email address
- Requires Google OAuth credentials from Google Cloud Console
- Ports 80 and 443 must be port-forwarded

Setup Requirements:
1. Create OAuth 2.0 credentials in Google Cloud Console
2. Set Redirect URI to: https://your-domain.com/auth/oauth2/callback
3. Add DNS A record pointing your domain to your server IP
4. Ensure ports 80 and 443 are port-forwarded from router
5. Set TEST=false in advanced settings once ready for production</Overview>
  <Networking>
    <Mode>bridge</Mode>
    <Publish>
      <Port>
        <HostPort>80</HostPort>
        <ContainerPort>80</ContainerPort>
        <Protocol>tcp</Protocol>
        <Description>HTTP</Description>
        <Access>External</Access>
      </Port>
      <Port>
        <HostPort>443</HostPort>
        <ContainerPort>443</ContainerPort>
        <Protocol>tcp</Protocol>
        <Description>HTTPS</Description>
        <Access>External</Access>
      </Port>
    </Publish>
  </Networking>
  <Data>
    <Volume>
      <HostDir>/mnt/user/appdata/yahlp/letsencrypt</HostDir>
      <ContainerDir>/etc/letsencrypt</ContainerDir>
      <Mode>rw</Mode>
      <Description>SSL Certificates</Description>
      <Access>rw</Access>
      <Exclude/>
      <IsFileShare>false</IsFileShare>
    </Volume>
    <Volume>
      <HostDir>/mnt/user/appdata/yahlp/config</HostDir>
      <ContainerDir>/etc/yahlp</ContainerDir>
      <Mode>rw</Mode>
      <Description>Configuration</Description>
      <Access>rw</Access>
      <Exclude/>
      <IsFileShare>false</IsFileShare>
    </Volume>
    <Volume>
      <HostDir>/mnt/user/appdata/yahlp/logs</HostDir>
      <ContainerDir>/var/log/apache2</ContainerDir>
      <Mode>rw</Mode>
      <Description>Apache Logs</Description>
      <Access>rw</Access>
      <Exclude/>
      <IsFileShare>false</IsFileShare>
    </Volume>
  </Data>

  <Environment>
    <Variable><Name>ACCESS_MODE</Name><Value>public</Value></Variable>
    <Variable><Name>DOMAIN</Name><Value></Value></Variable>
    <Variable><Name>EMAIL</Name><Value></Value></Variable>
    <Variable><Name>DASHBOARD_NAME</Name><Value>YAHLP</Value></Variable>
    <Variable><Name>DASHBOARD_STYLE</Name><Value>modern</Value></Variable>
    <Variable><Name>DASHBOARD_COLOR</Name><Value>#00A99D</Value></Variable>
    <Variable><Name>AUTHTYPE</Name><Value>google</Value></Variable>
    <Variable><Name>GOOGLE_CLIENT_ID</Name><Value></Value></Variable>
    <Variable><Name>GOOGLE_CLIENT_SECRET</Name><Value></Value></Variable>
    <Variable><Name>GOOGLE_REDIRECT_URI</Name><Value></Value></Variable>
    <Variable><Name>TZ</Name><Value>UTC</Value></Variable>
  </Environment>

  <Config Name="Access Mode" Target="ACCESS_MODE" Default="public" Mode="" Type="Variable" Display="advanced" Required="false" Mask="false"/>
  <Config Name="Domain" Target="DOMAIN" Default="" Mode="" Description="Your domain (e.g., example.com)" Type="Variable" Display="always" Required="true" Mask="false"/>
  <Config Name="Email" Target="EMAIL" Default="" Mode="" Description="Email for Let's Encrypt notifications" Type="Variable" Display="always" Required="true" Mask="false"/>
  <Config Name="Google Client ID" Target="GOOGLE_CLIENT_ID" Default="" Mode="" Description="From Google Cloud Console" Type="Variable" Display="always" Required="true" Mask="false"/>
  <Config Name="Google Client Secret" Target="GOOGLE_CLIENT_SECRET" Default="" Mode="" Description="From Google Cloud Console" Type="Variable" Display="always" Required="true" Mask="true"/>
  <Config Name="Google Redirect URI" Target="GOOGLE_REDIRECT_URI" Default="" Mode="" Description="https://your-domain.com/auth/oauth2/callback" Type="Variable" Display="always" Required="true" Mask="false"/>
  <Config Name="Dashboard Name" Target="DASHBOARD_NAME" Default="YAHLP" Mode="" Type="Variable" Display="always" Required="false" Mask="false"/>
  <Config Name="Dashboard Layout" Target="DASHBOARD_STYLE" Default="modern" Mode="" Description="Choose: classic, modern, sleek, minimal" Type="Variable" Display="always" Required="false" Mask="false"/>
  <Config Name="Accent Color" Target="DASHBOARD_COLOR" Default="#00A99D" Mode="" Type="Variable" Display="always" Required="false" Mask="false"/>
  <Config Name="Timezone" Target="TZ" Default="UTC" Mode="" Type="Variable" Display="advanced" Required="false" Mask="false"/>
</Container>
