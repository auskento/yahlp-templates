  <Repository>ghcr.io/auskento/yahlp:latest</Repository>
  <Registry>https://ghcr.io</Registry>
  <Network>bridge</Network>
  <MyIP></MyIP>
  <Shell>sh</Shell>
  <Privileged>false</Privileged>
  <Support>https://github.com/auskento/yahlp</Support>
  <Project>https://github.com/auskento/yahlp</Project>
  <Overview>yahlp - Public Deployment with Entra ID OAuth&amp;#13;&amp;#13;This template is pre-configured for:&amp;#13;- Public mode: External access on HTTPS via Let&apos;s Encrypt&amp;#13;- Entra ID (Microsoft) OAuth2 authentication&amp;#13;- Automatic SSL certificate generation and renewal&amp;#13;&amp;#13;IMPORTANT - Network Configuration:&amp;#13;This container requires its own IP address to properly expose ports 80 and 443. Do NOT use bridge, host, or other networking modes. Assign a static IP on your network to ensure reliable port exposure for HTTPS and Let&apos;s Encrypt validation.&amp;#13;&amp;#13;Required settings:&amp;#13;1. DOMAIN: Your domain name (e.g., yourdomain.com)&amp;#13;2. EMAIL: Email for Let&apos;s Encrypt certificate notifications&amp;#13;3. Entra ID credentials (CLIENT_ID, CLIENT_SECRET, REDIRECT_URI, PROVIDER_METADATA_URL, CRYPTO_PASSPHRASE)&amp;#13;4. Service URLs: Configure your backend service URLs&amp;#13;&amp;#13;Optional settings:&amp;#13;- STYLE: Dashboard style (classic, modern, sleek, minimal)&amp;#13;- DASHBOARD_NAME, DASHBOARD_ICON, DASHBOARD_LANDING&amp;#13;- EMBY_DOMAIN, PLEX_DOMAIN: For dedicated subdomains&amp;#13;- Service enable/disable flags&amp;#13;&amp;#13;Documentation: https://github.com/auskento/yahlp</Overview>
  <Category>Network:Web</Category>
  <WebUI>https://yourdomain.com</WebUI>
  <TemplateURL>https://raw.githubusercontent.com/auskento/yahlp-templates/main/templates/yahlp-public-entra.xml</TemplateURL>
  <Icon>https://raw.githubusercontent.com/auskento/yahlp/main/yahlp-150.png</Icon>
  <ExtraParams></ExtraParams>
  <PostArgs></PostArgs>
  <DonateText></DonateText>
  <DonateLink></DonateLink>
  <Description>yahlp - Public Mode with Entra ID (Microsoft) OAuth2 authentication. Full external access with HTTPS via Let&apos;s Encrypt, protected by username/password.</Description>
  <Networking>
    <Mode>bridge</Mode>
    <Publish>
      <Port>
        <HostPort>80</HostPort>
        <ContainerPort>80</ContainerPort>
        <Protocol>tcp</Protocol>
      </Port>
      <Port>
        <HostPort>443</HostPort>
        <ContainerPort>443</ContainerPort>
        <Protocol>tcp</Protocol>
      </Port>
    </Publish>
  </Networking>
