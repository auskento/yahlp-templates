  <Config Name="Seerr URL" Target="SEERR_URL" Default="http://seerr:5055" Mode="" Description="Your local url" Type="Variable" Display="always" Required="false" Mask="false" />
  <Config Name="Seerr Domain" Target="SEERR_DOMAIN" Default="seerr.yourdomain.com" Mode="" Description="Subdomain for Seerr" Type="Variable" Display="always" Required="false" Mask="false" />
  <Config Name="Seerr Redirect URI" Target="SEERR_REDIRECT_URI" Default="https://seerr.yourdomain.com/oauth2callback" Mode="" Description="OAuth redirect URI - configure in Entra or Google" Type="Variable" Display="advanced" Required="false" Mask="false" />
