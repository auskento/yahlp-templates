  <Config Name="Entra Client Secret" Target="ENTRA_CLIENT_SECRET" Default="" Mode="" Description="From Azure Portal" Type="Variable" Display="always" Required="false" Mask="true" />
  <Config Name="Entra Tenant ID" Target="ENTRA_TENANT_ID" Default="" Mode="" Description="Your Azure Tenant ID" Type="Variable" Display="always" Required="false" Mask="false" />
