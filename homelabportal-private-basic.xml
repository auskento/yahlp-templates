    </Variable>
    <Variable>
      <Name>ENABLE_TRANSMISSION</Name>
      <Value>false</Value>
    </Variable>
    <Variable>
      <Name>TRANSMISSION_URL</Name>
      <Value>http://YOUR_BACKEND_HOST:9091</Value>
    </Variable>
    <Variable>
      <Name>ENABLE_QBITTORRENT</Name>
      <Value>false</Value>
    </Variable>
    <Variable>
      <Name>QBITTORRENT_URL</Name>
      <Value>http://YOUR_BACKEND_HOST:8585</Value>
    </Variable>
    <!-- CONTENT Services -->
