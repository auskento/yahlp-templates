  <Repository>ghcr.io/auskento/yahlp:latest</Repository>
  <Registry>https://ghcr.io</Registry>
  <Network>bridge</Network>
  <MyIP/>
  <Shell>bash</Shell>
  <Privileged>false</Privileged>
  <Support>https://github.com/auskento/yahlp</Support>
  <Project>https://github.com/auskento/yahlp</Project>
  <Category>Network:Web</Category>
  <TemplateURL>https://raw.githubusercontent.com/auskento/yahlp-templates/main/templates/yahlp-public-basic.xml</TemplateURL>
  <Icon>https://raw.githubusercontent.com/auskento/yahlp/main/yahlp-150.png</Icon>
  <WebUI>https://yourdomain.com</WebUI>
  <PostArgs/>
  <CloudSync>false</CloudSync>
  <Description>yahlp - Public Mode with Basic Authentication. Full external access with HTTPS via Let's Encrypt, protected by username/password.</Description>
  <Overview>yahlp - Public Deployment with Basic Auth&#13;&#13;This template is pre-configured for:&#13;- Public mode: External access on HTTPS via Let's Encrypt&#13;- Basic authentication with username/password&#13;- Automatic SSL certificate generation and renewal&#13;&#13;IMPORTANT - Network Configuration:&#13;This container requires its own IP address to properly expose ports 80 and 443. Do NOT use bridge, host, or other networking modes. Assign a static IP on your network to ensure reliable port exposure for HTTPS and Let's Encrypt validation.&#13;&#13;Required settings:&#13;1. DOMAIN: Your domain name (e.g., yourdomain.com)&#13;2. EMAIL: Email for Let's Encrypt certificate notifications&#13;3. BASIC_AUTH_CREDENTIALS: Username and password (format: user:pass)&#13;4. Service URLs: Configure your backend service URLs&#13;&#13;Optional settings:&#13;- STYLE: Dashboard style (classic, modern, sleek, minimal)&#13;- DASHBOARD_NAME, DASHBOARD_ICON, DASHBOARD_LANDING&#13;- EMBY_DOMAIN, PLEX_DOMAIN: For dedicated subdomains&#13;- Service enable/disable flags&#13;&#13;Documentation: https://github.com/auskento/yahlp</Overview>
  <Networking>
    <Mode>br0</Mode>
    <Publish>
      <Port>
        <HostPort>80</HostPort>
        <ContainerPort>80</ContainerPort>
        <Protocol>tcp</Protocol>
        <Description>HTTP (for Let's Encrypt validation)</Description>
        <Access>External</Access>
      </Port>
      <Port>
        <HostPort>443</HostPort>
        <ContainerPort>443</ContainerPort>
        <Protocol>tcp</Protocol>
        <Description>HTTPS</Description>
        <Access>External</Access>
      </Port>
    </Publish>
  </Networking>
  <Data>
    <Volume>
      <HostDir>/mnt/user/appdata/yahlp-public/letsencrypt</HostDir>
      <ContainerDir>/etc/letsencrypt</ContainerDir>
      <Mode>rw</Mode>
      <Description>SSL Certificates</Description>
      <Access>rw</Access>
      <Exclude/>
      <IsFileShare>false</IsFileShare>
    </Volume>
    <Volume>
      <HostDir>/mnt/user/appdata/yahlp-public/logs</HostDir>
      <ContainerDir>/var/log/apache2</ContainerDir>
      <Mode>rw</Mode>
      <Description>Apache Logs</Description>
      <Access>rw</Access>
      <Exclude/>
      <IsFileShare>false</IsFileShare>
    </Volume>
  </Data>

