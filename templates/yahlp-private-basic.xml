<?xml version="1.0" encoding="utf-8"?>
<Container version="2">
  <Name>YAHLP-Private</Name>
  <Repository>auskento/yahlp</Repository>
  <Registry>https://hub.docker.com</Registry>
  <Network>bridge</Network>
  <MyIP/>
  <Shell>bash</Shell>
  <Privileged>false</Privileged>
  <Support>https://github.com/auskento/YAHLP</Support>
  <Project>https://github.com/auskento/YAHLP</Project>
  <Category>Network:Web</Category>
  <TemplateURL>https://raw.githubusercontent.com/auskento/yahlp-templates/main/templates/yahlp-private-basic.xml</TemplateURL>
  <Icon>https://raw.githubusercontent.com/auskento/YAHLP/main/html/icons/yahlp.png</Icon>
  <WebUI>http://[IP]:80/</WebUI>
  <CloudSync>false</CloudSync>
  <Description>YAHLP - Private Mode (HTTP + Basic Auth). Simple setup for internal networks with username/password protection. No domain or certificates required.</Description>
  <Overview>YAHLP - Yet Another HomeLab Portal - Private Mode Template

Configured for private network deployment with:
- HTTP access only (port 80)
- Basic authentication (username/password)
- Internal network access

Perfect for private lab environments without public exposure.</Overview>
  <Networking>
    <Mode>bridge</Mode>
    <Publish>
      <Port>
        <HostPort>80</HostPort>
        <ContainerPort>80</ContainerPort>
        <Protocol>tcp</Protocol>
        <Description>HTTP</Description>
        <Access>External</Access>
      </Port>
    </Publish>
  </Networking>
  <Data>
    <Volume>
      <HostDir>/mnt/user/appdata/yahlp/letsencrypt</HostDir>
      <ContainerDir>/etc/letsencrypt</ContainerDir>
      <Mode>rw</Mode>
      <Description>SSL Certificates</Description>
      <Access>rw</Access>
      <Exclude/>
      <IsFileShare>false</IsFileShare>
    </Volume>
    <Volume>
      <HostDir>/mnt/user/appdata/yahlp/config</HostDir>
      <ContainerDir>/etc/yahlp</ContainerDir>
      <Mode>rw</Mode>
      <Description>Configuration</Description>
      <Access>rw</Access>
      <Exclude/>
      <IsFileShare>false</IsFileShare>
    </Volume>
    <Volume>
      <HostDir>/mnt/user/appdata/yahlp/logs</HostDir>
      <ContainerDir>/var/log/apache2</ContainerDir>
      <Mode>rw</Mode>
      <Description>Apache Logs</Description>
      <Access>rw</Access>
      <Exclude/>
      <IsFileShare>false</IsFileShare>
    </Volume>
  </Data>

  <Environment>
    <Variable>
      <Name>ACCESS_MODE</Name>
      <Value>private</Value>
      <Description>Choose: public (HTTPS with Let's Encrypt) or private (HTTP on internal network)</Description>
      <Display>advanced</Display>
      <Required>false</Required>
      <Mask>false</Mask>
    </Variable>
    <Variable>
      <Name>IP</Name>
      <Value></Value>
      <Description>Server IP for private mode (e.g., 192.168.1.100)</Description>
      <Display>always</Display>
      <Required>true</Required>
      <Mask>false</Mask>
    </Variable>
    <Variable>
      <Name>TZ</Name>
      <Value>UTC</Value>
      <Description>Container timezone (e.g., Australia/Sydney, UTC, US/Eastern). Leave blank for default.</Description>
      <Display>advanced</Display>
      <Required>false</Required>
      <Mask>false</Mask>
    </Variable>
    <Variable>
      <Name>DASHBOARD_NAME</Name>
      <Value>YAHLP</Value>
      <Description>Title displayed in dashboard</Description>
      <Display>always</Display>
      <Required>false</Required>
      <Mask>false</Mask>
    </Variable>
    <Variable>
      <Name>DASHBOARD_STYLE</Name>
      <Value>modern</Value>
      <Description>Choose: classic, modern, sleek, minimal. Append :only to disable style switcher (e.g., classic:only)</Description>
      <Display>always</Display>
      <Required>false</Required>
      <Mask>false</Mask>
    </Variable>
    <Variable>
      <Name>DASHBOARD_COLOR</Name>
      <Value>#00A99D</Value>
      <Description>Accent color (hex code, e.g., #00A99D)</Description>
      <Display>always</Display>
      <Required>false</Required>
      <Mask>false</Mask>
    </Variable>
    <Variable>
      <Name>DASHBOARD_LANDING</Name>
      <Value></Value>
      <Description>Default page to load when accessing dashboard. Examples: radarr, sonarr, sonarr/calendar, radarr/upcoming. Leave blank to show YAHLP welcome screen.</Description>
      <Display>always</Display>
      <Required>false</Required>
      <Mask>false</Mask>
    </Variable>
    <Variable>
      <Name>DASHBOARD_ORDER</Name>
      <Value>SAB,GET,HYD,TRA,QBI,DEL,PRO,JAC,SON,RAD,LID,WHI,SEE,BAZ,TAU,MNT,JEL,PLX,EMB</Value>
      <Description>Service display order (3-letter codes, only enabled services shown). SAB=SABnzbd, GET=NZBGet, HYD=NZBHydra, TRA=Transmission, QBI=qBittorrent, DEL=Deluge, PRO=Prowlarr, JAC=Jackett, SON=Sonarr, RAD=Radarr, LID=Lidarr, WHI=Whisparr, SEE=Seerr, BAZ=Bazarr, TAU=Tautulli, MNT=Maintainerr, JEL=Jellyfin, PLX=Plex, EMB=Emby</Description>
      <Display>advanced</Display>
      <Required>false</Required>
      <Mask>false</Mask>
    </Variable>
    <Variable>
      <Name>AUTHTYPE</Name>
      <Value>basic</Value>
      <Description>Choose: none, basic, google, entra</Description>
      <Display>always</Display>
      <Required>true</Required>
      <Mask>false</Mask>
    </Variable>
    <Variable>
      <Name>BASIC_AUTH_CREDENTIALS</Name>
      <Value></Value>
      <Description>Format: user:pass or user1:pass1|user2:pass2</Description>
      <Display>always</Display>
      <Required>true</Required>
      <Mask>true</Mask>
    </Variable>
  </Environment>

  <Config Name="Access Mode" Target="ACCESS_MODE" Default="private" Mode="" Description="Set to private for internal networks (HTTP only)" Type="Variable" Display="advanced" Required="false" Mask="false" />
  <Config Name="Internal IP" Target="IP" Default="" Mode="" Description="Your server IP (e.g., 192.168.1.100)" Type="Variable" Display="always" Required="true" Mask="false" />
  <Config Name="Timezone" Target="TZ" Default="UTC" Mode="" Description="Container timezone (e.g., Australia/Sydney, UTC, US/Eastern). Leave blank for default." Type="Variable" Display="advanced" Required="false" Mask="false" />
  <Config Name="Dashboard Name" Target="DASHBOARD_NAME" Default="YAHLP" Mode="" Description="Title displayed in dashboard" Type="Variable" Display="always" Required="false" Mask="false" />
  <Config Name="Dashboard Style" Target="DASHBOARD_STYLE" Default="modern" Mode="" Description="Choose: classic, modern, sleek, minimal. Append :only to disable style switcher (e.g., classic:only)" Type="Variable" Display="always" Required="false" Mask="false" />
  <Config Name="Dashboard Color" Target="DASHBOARD_COLOR" Default="#00A99D" Mode="" Description="Accent color (hex code, e.g., #00A99D)" Type="Variable" Display="always" Required="false" Mask="false" />
  <Config Name="Dashboard Landing Page" Target="DASHBOARD_LANDING" Default="" Mode="" Description="Default page to load when accessing dashboard. Examples: radarr, sonarr, sonarr/calendar, radarr/upcoming. Leave blank to show YAHLP welcome screen." Type="Variable" Display="always" Required="false" Mask="false" />
  <Config Name="Dashboard Service Order" Target="DASHBOARD_ORDER" Default="SAB,GET,HYD,TRA,QBI,DEL,PRO,JAC,SON,RAD,LID,WHI,SEE,BAZ,TAU,MNT,JEL,PLX,EMB" Mode="" Description="Service display order (3-letter codes, only enabled services shown)." Type="Variable" Display="advanced" Required="false" Mask="false" />
  <Config Name="Authentication Type" Target="AUTHTYPE" Default="basic" Mode="" Description="Choose: none, basic, google, entra" Type="Variable" Display="always" Required="true" Mask="false" />
  <Config Name="Basic Auth Credentials" Target="BASIC_AUTH_CREDENTIALS" Default="" Mode="" Description="Format: user:pass or user1:pass1|user2:pass2" Type="Variable" Display="always" Required="true" Mask="true" />
</Container>
