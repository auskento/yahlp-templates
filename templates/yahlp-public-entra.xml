  <Config Name="Enable Deluge" Target="DELUGE_ENABLED" Default="false|true" Mode="" Description="Deluge - Torrent Client" Type="Variable" Display="always" Required="false" Mask="false" />
  <Config Name="Deluge URL" Target="DELUGE_URL" Default="http://deluge:8112" Mode="" Description="Your local url" Type="Variable" Display="always" Required="false" Mask="false" />
  <!-- CONTENT SERVICES -->
