  <Config Name="SABnzbd Icon" Target="ICON_URL_SABNZBD" Default="" Mode="" Description="Custom icon URL (leave blank for included)" Type="Variable" Display="always" Required="false" Mask="false"/>

  <Config Name="Enable NZBGet" Target="ENABLE_NZBGET" Default="false" Mode="" Description="NZBGet - Usenet Client (Set User and Pass below to the NZBGet account for auth bypass, leaving blank will have NZBGet prompt for its credentials" Type="Variable" Display="always" Required="false" Mask="false"/>
