  <Config Name="Entra Crypto Passphrase" Target="ENTRA_CRYPTO_PASSPHRASE" Default="" Mode="" Description="Encryption passphrase for Entra tokens" Type="Variable" Display="always" Required="false" Mask="true" />
  <Config Name="Entra Metadata URL" Target="ENTRA_PROVIDER_METADATA_URL" Default="" Mode="" Description="OpenID metadata URL for Entra" Type="Variable" Display="always" Required="false" Mask="false" />
  <!-- USENET SERVICES -->
