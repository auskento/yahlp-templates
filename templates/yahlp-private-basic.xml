<?xml version="1.0" encoding="utf-8"?>
<Container version="2">
  <Name>YAHLP-Private</Name>
  <Repository>ghcr.io/auskento/yahlp</Repository>
  <Registry>https://ghcr.io</Registry>
  <Network>bridge</Network>
  <MyIP/>
  <Shell>bash</Shell>
  <Privileged>false</Privileged>
  <Support>https://github.com/auskento/YAHLP</Support>
  <Project>https://github.com/auskento/YAHLP</Project>
  <Category>Network:Web</Category>
  <TemplateURL>https://raw.githubusercontent.com/auskento/yahlp-templates/main/templates/yahlp-private-basic.xml</TemplateURL>
  <Icon>https://raw.githubusercontent.com/auskento/YAHLP/main/html/icons/yahlp.png</Icon>
  <WebUI>http://[IP]:80/</WebUI>
  <CloudSync>false</CloudSync>
  <Description>YAHLP - Private Mode (HTTP + Basic Auth). Simple setup for internal networks with username/password protection. No domain or certificates required.</Description>
  <Overview>YAHLP - Yet Another HomeLab Portal - Private Mode Template

Configured for private network deployment with:
- HTTP access only (port 80)
- Basic authentication (username/password)
- Internal network access

Perfect for private lab environments without public exposure.</Overview>

  <!-- PORTS -->
  <Config Name="HTTP" Target="80" Default="80" Mode="tcp" Description="HTTP" Type="Port" Display="always" Required="true" Mask="false">80</Config>
  <!-- DEPLOYMENT & ACCESS MODE -->
  <Config Name="Let's Encrypt Test Mode" Target="DASHBOARD_TEST" Default="true|false" Mode="" Description="Let's Encrypt --dry-run mode (test without rate limits). WARNING: Certificates will NOT be issued. Set to false when ready for production." Type="Variable" Display="always" Required="false" Mask="false"/>
  <Config Name="Access Mode" Target="ACCESS_MODE" Default="private" Mode="" Description="Choose: public (HTTPS with Let's Encrypt) or private (HTTP on internal network)" Type="Variable" Display="always" Required="true" Mask="false" />
  <Config Name="Domain (Public)" Target="DOMAIN" Default="" Mode="" Description="Your domain for public mode (e.g., yahlp.yourdomain.com)" Type="Variable" Display="always" Required="false" Mask="false" />
  <Config Name="Email (Public)" Target="EMAIL" Default="" Mode="" Description="Email for Let's Encrypt notifications (public mode only)" Type="Variable" Display="always" Required="false" Mask="false" />
  <Config Name="Internal IP (Private)" Target="IP" Default="" Mode="" Description="Server IP for private mode (e.g., 192.168.1.100)" Type="Variable" Display="always" Required="false" Mask="false" />
  <Config Name="Timezone" Target="TZ" Default="" Mode="" Description="Container timezone (e.g., Australia/Sydney, UTC, US/Eastern)" Type="Variable" Display="advanced" Required="false" Mask="false" />
  <!-- DASHBOARD SETTINGS -->
  <Config Name="Dashboard Name" Target="DASHBOARD_NAME" Default="YAHLP" Mode="" Description="Displayed in browser title and dashboard" Type="Variable" Display="always" Required="false" Mask="false" />
  <Config Name="Dashboard Layout" Target="DASHBOARD_STYLE" Default="modern" Mode="" Description="Choose: classic, modern, sleek, minimal" Type="Variable" Display="always" Required="false" Mask="false" />
  <Config Name="Accent Color" Target="DASHBOARD_COLOR" Default="" Mode="" Description="Hex color for UI accents (e.g., #00A99D)" Type="Variable" Display="always" Required="false" Mask="false" />
  <Config Name="Dashboard Landing" Target="DASHBOARD_LANDING" Default="" Mode="" Description="Default page on load (e.g., sonarr, radarr/upcoming). Leave blank for grid." Type="Variable" Display="always" Required="false" Mask="false" />
  <Config Name="Service Display Order" Target="DASHBOARD_ORDER" Default="SAB,GET,HYD,TRA,QBI,DEL,PRO,JAC,SON,RAD,LID,WHI,SEE,BAZ,TAU,MNT,JEL,PLX,EMB" Mode="" Description="Comma-separated service codes for display order" Type="Variable" Display="always" Required="false" Mask="false" />
  <Config Name="Sites Display Order" Target="DASHBOARD_SITES" Default="" Mode="" Description="Comma-separated list for internal websites display order" Type="Variable" Display="always" Required="false" Mask="false" />
    <!-- AUTHENTICATION -->
  <Config Name="Authentication Type" Target="AUTHTYPE" Default="none|basic|google|entra" Mode="" Description="Choose: none, basic, google, entra" Type="Variable" Display="always" Required="true" Mask="false" />
  <Config Name="Basic Auth Credentials" Target="BASIC_AUTH_CREDENTIALS" Default="" Mode="" Description="Format: user:pass or user1:pass1|user2:pass2" Type="Variable" Display="always" Required="false" Mask="true" />
  <!-- USENET SERVICES -->
  <Config Name="Enable SABnzbd" Target="SABNZBD_ENABLED" Default="false|true" Mode="" Description="SABnzbd - Usenet Client (Config - Special - url_base() to /sabnzbd)" Type="Variable" Display="always" Required="false" Mask="false" />
  <Config Name="SABnzbd URL" Target="SABNZBD_URL" Default="http://sabnzbd:8080" Mode="" Description="Your local URL" Type="Variable" Display="always" Required="false" Mask="false" />
  <Config Name="SABnzbd API Key" Target="SABNZBD_API_KEY" Default="" Mode="" Description="API key from SABnzbd settings" Type="Variable" Display="always" Required="false" Mask="true" />
  <Config Name="SABnzbd Icon" Target="SABNZBD_ICON_URL" Default="" Mode="" Description="URL to download custom SABnzbd icon (leave blank for builtin)" Type="Variable" Display="always" Required="false" Mask="false" />
  <Config Name="Enable NZBGet" Target="NZBGET_ENABLED" Default="false|true" Mode="" Description="NZBGet - Usenet Client (Set User and Pass below to bypass NZBGet auth" Type="Variable" Display="always" Required="false" Mask="false" />
  <Config Name="NZBGet URL" Target="NZBGET_URL" Default="http://nzbget:6789" Mode="" Description="Your local URL" Type="Variable" Display="always" Required="false" Mask="false" />
  <Config Name="NZBGet Username" Target="NZBGET_USER" Default="" Mode="" Description="NZBGet username (if required)" Type="Variable" Display="always" Required="false" Mask="true" />
  <Config Name="NZBGet Password" Target="NZBGET_PASS" Default="" Mode="" Description="NZBGet password (if required)" Type="Variable" Display="always" Required="false" Mask="true" />
  <Config Name="NZBGet Icon" Target="NZBGET_ICON_URL" Default="" Mode="" Description="URL to download custom NZBGet icon (leave blank for builtin)" Type="Variable" Display="always" Required="false" Mask="false" />
  <Config Name="Enable NZBHydra" Target="NZBHYDRA_ENABLED" Default="false|true" Mode="" Description="NZBHydra - Usenet Meta Indexer (Config - Main - URLBase to /nzbhydra)" Type="Variable" Display="always" Required="false" Mask="false" />
  <Config Name="NZBHydra URL" Target="NZBHYDRA_URL" Default="http://nzbhydra:5076" Mode="" Description="Your local url" Type="Variable" Display="always" Required="false" Mask="false" />
  <Config Name="NZBHydra API Key" Target="NZBHYDRA_API_KEY" Default="" Mode="" Description="API key from NZBHydra settings" Type="Variable" Display="always" Required="false" Mask="true" />
  <Config Name="NZBHydra Icon" Target="NZBHYDRA_ICON_URL" Default="" Mode="" Description="URL to download custom NZBHydra icon (leave blank for builtin)" Type="Variable" Display="always" Required="false" Mask="false" />
  <!-- TORRENTS SERVICES -->
  <Config Name="Enable Transmission" Target="TRANSMISSION_ENABLED" Default="false|true" Mode="" Description="Transmission - Torrent Client" Type="Variable" Display="always" Required="false" Mask="false" />
  <Config Name="Transmission URL" Target="TRANSMISSION_URL" Default="http://transmission:9091" Mode="" Description="Your local url" Type="Variable" Display="always" Required="false" Mask="false" />
  <Config Name="Transmission Icon" Target="TRANSMISSION_ICON_URL" Default="" Mode="" Description="URL to download custom Transmission icon (leave blank for builtin)" Type="Variable" Display="always" Required="false" Mask="false" />
  <Config Name="Enable qBittorrent" Target="QBITTORRENT_ENABLED" Default="false|true" Mode="" Description="qBittorrent - Torrent Client" Type="Variable" Display="always" Required="false" Mask="false" />
  <Config Name="qBittorrent URL" Target="QBITTORRENT_URL" Default="http://qbittorrent:8080" Mode="" Description="Your local url (Check port for conflict, default to same port as other apps)" Type="Variable" Display="always" Required="false" Mask="false" />
  <Config Name="qBittorrent API Key" Target="QBITTORRENT_API_KEY" Default="" Mode="" Description="API key from qBittorrent settings" Type="Variable" Display="always" Required="false" Mask="true" />
  <Config Name="qBittorrent Icon" Target="QBITTORRENT_ICON_URL" Default="" Mode="" Description="URL to download custom Qbittorreny icon (leave blank for builtin)" Type="Variable" Display="always" Required="false" Mask="false" />
  <Config Name="Enable Deluge" Target="DELUGE_ENABLED" Default="false|true" Mode="" Description="Deluge - Torrent Client" Type="Variable" Display="always" Required="false" Mask="false" />
  <Config Name="Deluge URL" Target="DELUGE_URL" Default="http://deluge:8112" Mode="" Description="Your local url" Type="Variable" Display="always" Required="false" Mask="false" />
  <Config Name="Deluge Password" Target="DELUGE_PASSWORD" Default="" Mode="" Description="Password for Deluge web UI login" Type="Variable" Display="always" Required="false" Mask="true" />
  <Config Name="Deluge Icon" Target="DELUGE_ICON_URL" Default="" Mode="" Description="URL to download custom Deluge icon (leave blank for builtin)" Type="Variable" Display="always" Required="false" Mask="false" />
  <!-- CONTENT SERVICES -->
  <Config Name="Enable Sonarr" Target="SONARR_ENABLED" Default="false|true" Mode="" Description="Sonarr - TV Show Automation (Settings - General - URL Base to /sonarr)" Type="Variable" Display="always" Required="false" Mask="false" />
  <Config Name="Sonarr URL" Target="SONARR_URL" Default="http://sonarr:8989" Mode="" Description="Your local url" Type="Variable" Display="always" Required="false" Mask="false" />
  <Config Name="Sonarr API Key" Target="SONARR_API_KEY" Default="" Mode="" Description="API key from Sonarr settings" Type="Variable" Display="always" Required="false" Mask="true" />
  <Config Name="Sonarr Landing" Target="SONARR_LANDING" Default="sonarr" Mode="" Description="Landing page (e.g., sonarr, sonarr/calendar)" Type="Variable" Display="always" Required="false" Mask="false" />
  <Config Name="Sonarr Icon" Target="SONARR_ICON_URL" Default="" Mode="" Description="URL to download custom Sonarr icon (leave blank for builtin)" Type="Variable" Display="always" Required="false" Mask="false" />
  <Config Name="Enable Radarr" Target="RADARR_ENABLED" Default="false|true" Mode="" Description="Radarr - Movie Automation ((Settings - General - URL Base to /radarr)" Type="Variable" Display="always" Required="false" Mask="false" />
  <Config Name="Radarr URL" Target="RADARR_URL" Default="http://radarr:7878" Mode="" Description="Your local url" Type="Variable" Display="always" Required="false" Mask="false" />
  <Config Name="Radarr API Key" Target="RADARR_API_KEY" Default="" Mode="" Description="API key from Radarr settings" Type="Variable" Display="always" Required="false" Mask="true" />
  <Config Name="Radarr Landing" Target="RADARR_LANDING" Default="radarr" Mode="" Description="Landing page (e.g., radarr, radarr/calendar)" Type="Variable" Display="always" Required="false" Mask="false" />
  <Config Name="Radarr Icon" Target="RADARR_ICON_URL" Default="" Mode="" Description="URL to download custom Radarr icon (leave blank for builtin)" Type="Variable" Display="always" Required="false" Mask="false" />
  <Config Name="Enable Whisparr" Target="WHISPARR_ENABLED" Default="false|true" Mode="" Description="Whisparr - Adult Content Automation (Settings - General - URL Base to /whisparr)" Type="Variable" Display="always" Required="false" Mask="false" />
  <Config Name="Whisparr URL" Target="WHISPARR_URL" Default="http://whisparr:6969" Mode="" Description="Your local url" Type="Variable" Display="always" Required="false" Mask="false" />
  <Config Name="Whisparr API Key" Target="WHISPARR_API_KEY" Default="" Mode="" Description="API key from Whisparr settings" Type="Variable" Display="always" Required="false" Mask="true" />
  <Config Name="Whisparr Landing" Target="WHISPARR_LANDING" Default="whisparr" Mode="" Description="Landing page" Type="Variable" Display="always" Required="false" Mask="false" />
  <Config Name="Whisparr Icon" Target="WHISPARR_ICON_URL" Default="" Mode="" Description="URL to download custom Whisparr icon (leave blank for builtin)" Type="Variable" Display="always" Required="false" Mask="false" />
  <Config Name="Enable Lidarr" Target="LIDARR_ENABLED" Default="false|true" Mode="" Description="Lidarr - Music Automation (Settings - General - URL Base to to /lidarr)" Type="Variable" Display="always" Required="false" Mask="false" />
  <Config Name="Lidarr URL" Target="LIDARR_URL" Default="http://lidarr:8686" Mode="" Description="Your local url" Type="Variable" Display="always" Required="false" Mask="false" />
  <Config Name="Lidarr API Key" Target="LIDARR_API_KEY" Default="" Mode="" Description="API key from Lidarr settings" Type="Variable" Display="always" Required="false" Mask="true" />
  <Config Name="Lidarr Landing" Target="LIDARR_LANDING" Default="" Mode="" Description="Landing page" Type="Variable" Display="always" Required="false" Mask="false" />
  <Config Name="Lidarr Icon" Target="LIDARR_ICON_URL" Default="" Mode="" Description="URL to download custom Lidarr icon (leave blank for builtin)" Type="Variable" Display="always" Required="false" Mask="false" />
  <!-- SEARCH SERVICES -->
  <Config Name="Enable Prowlarr" Target="PROWLARR_ENABLED" Default="false|true" Mode="" Description="Prowlarr - Indexer Manager (Settings - General - URL Base to /prowlarr)" Type="Variable" Display="always" Required="false" Mask="false" />
  <Config Name="Prowlarr URL" Target="PROWLARR_URL" Default="http://prowlarr:9696" Mode="" Description="Your local url" Type="Variable" Display="always" Required="false" Mask="false" />
  <Config Name="Prowlarr API Key" Target="PROWLARR_API_KEY" Default="" Mode="" Description="API key from Prowlarr settings" Type="Variable" Display="always" Required="false" Mask="true" />
  <Config Name="Prowlarr Icon" Target="PROWLARR_ICON_URL" Default="" Mode="" Description="URL to download custom Prowlarr icon (leave blank for builtin)" Type="Variable" Display="always" Required="false" Mask="false" />
  <Config Name="Enable Jackett" Target="JACKETT_ENABLED" Default="false|true" Mode="" Description="Jackett - Indexer Aggregator (Config - Admin - url_base() to /jackett)" Type="Variable" Display="always" Required="false" Mask="false" />
  <Config Name="Jackett URL" Target="JACKETT_URL" Default="http://jackett:9117" Mode="" Description="Your local url" Type="Variable" Display="always" Required="false" Mask="false" />
  <Config Name="Jackett API Key" Target="JACKETT_API_KEY" Default="" Mode="" Description="API key from Jackett settings" Type="Variable" Display="always" Required="false" Mask="true" />
  <Config Name="Jackett Icon" Target="JACKETT_ICON_URL" Default="" Mode="" Description="URL to download custom Jackett icon (leave blank for builtin)" Type="Variable" Display="always" Required="false" Mask="false" />
  <Config Name="Enable Seerr" Target="SEERR_ENABLED" Default="false|true" Mode="" Description="Seerr - Request Manager (In Public mode, Seer uses a subdomain, make sure you have a DNS record configured)" Type="Variable" Display="always" Required="false" Mask="false" />
  <Config Name="Seerr URL" Target="SEERR_URL" Default="http://seerr:5055" Mode="" Description="Your local url" Type="Variable" Display="always" Required="false" Mask="false" />
  <Config Name="Seerr API Key" Target="SEERR_API_KEY" Default="" Mode="" Description="API key from Seerr settings" Type="Variable" Display="always" Required="false" Mask="true" />
  <Config Name="Seerr Icon" Target="SEERR_ICON_URL" Default="" Mode="" Description="URL to download custom Seerr icon (leave blank for builtin)" Type="Variable" Display="always" Required="false" Mask="false" />
  <Config Name="Enable Bazarr" Target="BAZARR_ENABLED" Default="false|true" Mode="" Description="Bazarr - Subtitle Manager (Settings - General - Base URL to /bazarr)" Type="Variable" Display="always" Required="false" Mask="false" />
  <Config Name="Bazarr URL" Target="BAZARR_URL" Default="http://bazarr:6767" Mode="" Description="Your local url" Type="Variable" Display="always" Required="false" Mask="false" />
  <Config Name="Bazarr API Key" Target="BAZARR_API_KEY" Default="" Mode="" Description="API key from Bazarr settings" Type="Variable" Display="always" Required="false" Mask="true" />
  <Config Name="Bazarr Icon" Target="BAZARR_ICON_URL" Default="" Mode="" Description="URL to download custom Bazarr icon (leave blank for builtin)" Type="Variable" Display="always" Required="false" Mask="false" />
  <!-- MEDIA SERVICES -->
  <Config Name="Enable Jellyfin" Target="JELLYFIN_ENABLED" Default="false|true" Mode="" Description="Jellyfin - Media Server (Settings -Admin Dash - Networking - Base URL /jellyfin)" Type="Variable" Display="always" Required="false" Mask="false" />
  <Config Name="Jellyfin URL" Target="JELLYFIN_URL" Default="http://jellyfin:8096" Mode="" Description="Your local url" Type="Variable" Display="always" Required="false" Mask="false" />
  <Config Name="Jellyfin API Key" Target="JELLYFIN_API_KEY" Default="" Mode="" Description="API key from Jellyfin settings" Type="Variable" Display="always" Required="false" Mask="true" />
  <Config Name="Jellyfin Icon" Target="JELLYFIN_ICON_URL" Default="" Mode="" Description="URL to download custom Jellyfin icon (leave blank for builtin)" Type="Variable" Display="always" Required="false" Mask="false" />
  <Config Name="Enable Emby" Target="EMBY_ENABLED" Default="false|true" Mode="" Description="Emby - Media Server (In public mode,Emby uses a subdomain, make sure you have a DNS record configured)" Type="Variable" Display="always" Required="false" Mask="false" />
  <Config Name="Emby URL" Target="EMBY_URL" Default="http://emby:8096" Mode="" Description="Your local url" Type="Variable" Display="always" Required="false" Mask="false" />
  <Config Name="Emby API Key" Target="EMBY_API_KEY" Default="" Mode="" Description="API key from Emby settings" Type="Variable" Display="always" Required="false" Mask="true" />
  <Config Name="Emby Icon" Target="EMBY_ICON_URL" Default="" Mode="" Description="URL to download custom Emby icon (leave blank for builtin)" Type="Variable" Display="always" Required="false" Mask="false" />
  <Config Name="Enable Plex" Target="PLEX_ENABLED" Default="false|true" Mode="" Description="Plex - Media Server (in public mode, Plex uses a subdomain, make sure you have a DNS record configured)" Type="Variable" Display="always" Required="false" Mask="false" />
  <Config Name="Plex URL" Target="PLEX_URL" Default="http://plex:32400" Mode="" Description="Your local url" Type="Variable" Display="always" Required="false" Mask="false" />
  <Config Name="Plex API Key" Target="PLEX_API_KEY" Default="" Mode="" Description="API key from Plex settings" Type="Variable" Display="always" Required="false" Mask="true" />
  <Config Name="Plex Icon" Target="PLEX_ICON_URL" Default="" Mode="" Description="URL to download custom Plex icon (leave blank for builtin)" Type="Variable" Display="always" Required="false" Mask="false" />
  <Config Name="Enable Tautulli" Target="TAUTULLI_ENABLED" Default="false|true" Mode="" Description="Tautulli - Plex Analytics (Settings - Show Advanced - Web Interface - Enable Proxy, Set Public Domain to https://yahlp.yourdomain.com/tautulli and HTTP root to /tautulli)" Type="Variable" Display="always" Required="false" Mask="false" />
  <Config Name="Tautulli URL" Target="TAUTULLI_URL" Default="http://tautulli:8181/tautulli" Mode="" Description="Your local url" Type="Variable" Display="always" Required="false" Mask="false" />
  <Config Name="Tautulli API Key" Target="TAUTULLI_API_KEY" Default="" Mode="" Description="API key from Tautulli settings" Type="Variable" Display="always" Required="false" Mask="true" />
  <Config Name="Tautulli Icon" Target="TAUTULLI_ICON_URL" Default="" Mode="" Description="URL to download custom Tautulli icon (leave blank for builtin)" Type="Variable" Display="always" Required="false" Mask="false" />
  <Config Name="Enable Maintainerr" Target="MAINTAINERR_ENABLED" Default="false|true" Mode="" Description="Maintainerr - Media Server Maintenance (Enable BASE_URL environment variable on its docker and set to /maintainerr)" Type="Variable" Display="always" Required="false" Mask="false" />
  <Config Name="Maintainerr URL" Target="MAINTAINERR_URL" Default="http://maintainerr:6246" Mode="" Description="Your local url" Type="Variable" Display="always" Required="false" Mask="false" />
  <Config Name="Maintainerr API Key" Target="MAINTAINERR_API_KEY" Default="" Mode="" Description="API key from Maintainerr settings" Type="Variable" Display="always" Required="false" Mask="true" />
  <Config Name="Maintainerr Icon" Target="MAINTAINERR_ICON_URL" Default="" Mode="" Description="URL to download custom Maintainerr icon (leave blank for builtin)" Type="Variable" Display="always" Required="false" Mask="false" />
  <!-- ADDITIONAL SETTINGS -->
  <Config Name="SSL_PROTOCOLS" Target="SSL_PROTOCOLS" Default="all -SSLv2 -SSLv3 -TLSv1 -TLSv1.1" Mode="" Description="SSL/TLS protocols to enable (Apache mod_ssl format)" Type="Variable" Display="advanced" Required="false" Mask="false"/>
  <Config Name="SSL_CIPHERS" Target="SSL_CIPHERS" Default="HIGH:!aNULL:!MD5" Mode="" Description="SSL cipher suite (Apache format)" Type="Variable" Display="advanced" Required="false" Mask="false"/>
  <Config Name="APACHE_LOG_LEVEL" Target="APACHE_LOG_LEVEL" Default="warn" Mode="" Description="Apache logging level: debug, info, notice, warn, crit" Type="Variable" Display="advanced" Required="false" Mask="false"/>
  <!-- STORAGE PATHS -->
  <Config Name="Configuration" Target="/etc/yahlp" Default="/mnt/user/appdata/yahlp" Mode="rw" Description="Configuration folder - store the yahlp and sites JSON5 files here - ENV Variables override config settings, remove the variable settings from the form.  Custom templates in the templates folder" Type="Path" Display="always" Required="true" Mask="false"/>
</Container>
