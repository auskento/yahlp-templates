  <Config Name="Radarr URL" Target="RADARR_URL" Default="http://YOUR_BACKEND_HOST:7878" Mode="" Description="Backend URL" Type="Variable" Display="always" Required="false" Mask="false"/>
  <Config Name="Enable Sonarr" Target="ENABLE_SONARR" Default="false" Mode="" Description="Sonarr - TV Show Automation" Type="Variable" Display="always" Required="false" Mask="false"/>
  <Config Name="Sonarr URL" Target="SONARR_URL" Default="http://YOUR_BACKEND_HOST:8989" Mode="" Description="Backend URL" Type="Variable" Display="always" Required="false" Mask="false"/>
  <Config Name="Enable Lidarr" Target="ENABLE_LIDARR" Default="false" Mode="" Description="Lidarr - Music Automation" Type="Variable" Display="always" Required="false" Mask="false"/>
  <Config Name="Lidarr URL" Target="LIDARR_URL" Default="http://YOUR_BACKEND_HOST:8686" Mode="" Description="Backend URL" Type="Variable" Display="always" Required="false" Mask="false"/>
  <Config Name="Enable Whisparr" Target="ENABLE_WHISPARR" Default="false" Mode="" Description="Whisparr - Adult Content" Type="Variable" Display="always" Required="false" Mask="false"/>
  <Config Name="Whisparr URL" Target="WHISPARR_URL" Default="http://YOUR_BACKEND_HOST:6969" Mode="" Description="Backend URL" Type="Variable" Display="always" Required="false" Mask="false"/>

  <!-- SEARCH Services -->
  <Config Name="Enable Prowlarr" Target="ENABLE_PROWLARR" Default="false" Mode="" Description="Prowlarr - Indexer Manager" Type="Variable" Display="always" Required="false" Mask="false"/>
  <Config Name="Prowlarr URL" Target="PROWLARR_URL" Default="http://YOUR_BACKEND_HOST:9696" Mode="" Description="Backend URL" Type="Variable" Display="always" Required="false" Mask="false"/>
  <Config Name="Enable Seerr" Target="ENABLE_SEERR" Default="false" Mode="" Description="Seerr - Request Manager" Type="Variable" Display="always" Required="false" Mask="false"/>
  <Config Name="Seerr URL" Target="SEERR_URL" Default="http://YOUR_BACKEND_HOST:5055" Mode="" Description="Backend URL" Type="Variable" Display="always" Required="false" Mask="false"/>
  <Config Name="Enable Bazarr" Target="ENABLE_BAZARR" Default="false" Mode="" Description="Bazarr - Subtitle Management" Type="Variable" Display="always" Required="false" Mask="false"/>
  <Config Name="Bazarr URL" Target="BAZARR_URL" Default="http://YOUR_BACKEND_HOST:6767" Mode="" Description="Backend URL" Type="Variable" Display="always" Required="false" Mask="false"/>

