  <Config Name="Enable NZBGet" Target="ENABLE_NZBGET" Default="false" Mode="" Description="NZBGet - Usenet Downloads" Type="Variable" Display="always" Required="false" Mask="false"/>
  <Config Name="NZBGet URL" Target="NZBGET_URL" Default="http://YOUR_BACKEND_HOST:6789/nzbget" Mode="" Description="Backend URL" Type="Variable" Display="always" Required="false" Mask="false"/>
  <Config Name="NZBGet Username" Target="NZBGET_USER" Default="" Mode="" Description="NZBGet username (optional)" Type="Variable" Display="always" Required="false" Mask="false"/>
  <Config Name="NZBGet Password" Target="NZBGET_PASS" Default="" Mode="" Description="NZBGet password (optional)" Type="Variable" Display="always" Required="false" Mask="true"/>
  <Config Name="Enable NZBHydra" Target="ENABLE_NZBHYDRA" Default="false" Mode="" Description="NZBHydra - NZB Indexer" Type="Variable" Display="always" Required="false" Mask="false"/>
  <Config Name="NZBHydra URL" Target="NZBHYDRA_URL" Default="http://YOUR_BACKEND_HOST:5076/nzbhydra" Mode="" Description="Backend URL" Type="Variable" Display="always" Required="false" Mask="false"/>

  <!-- TORRENTS Services -->
  <Config Name="Enable Deluge" Target="ENABLE_DELUGE" Default="false" Mode="" Description="Deluge - Torrent Client" Type="Variable" Display="always" Required="false" Mask="false"/>
  <Config Name="Deluge URL" Target="DELUGE_URL" Default="http://YOUR_BACKEND_HOST:8112" Mode="" Description="Backend URL" Type="Variable" Display="always" Required="false" Mask="false"/>
  <Config Name="Enable Transmission" Target="ENABLE_TRANSMISSION" Default="false" Mode="" Description="Transmission - Torrent Client" Type="Variable" Display="always" Required="false" Mask="false"/>
  <Config Name="Transmission URL" Target="TRANSMISSION_URL" Default="http://YOUR_BACKEND_HOST:9091" Mode="" Description="Backend URL" Type="Variable" Display="always" Required="false" Mask="false"/>
  <Config Name="Enable qBittorrent" Target="ENABLE_QBITTORRENT" Default="false" Mode="" Description="qBittorrent - Torrent Client" Type="Variable" Display="always" Required="false" Mask="false"/>
