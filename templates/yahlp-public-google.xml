<?xml version="1.0" encoding="utf-8"?>
<Container version="2">
  <Name>yahlp-public-google</Name>
  <Repository>ghcr.io/auskento/yahlp:latest</Repository>
  <Registry>https://ghcr.io</Registry>
  <Network>bridge</Network>
  <MyIP/>
  <Shell>bash</Shell>
  <Privileged>false</Privileged>
  <Support>https://github.com/auskento/yahlp</Support>
  <Project>https://github.com/auskento/yahlp</Project>
  <Category>Network:Web</Category>
  <TemplateURL>https://raw.githubusercontent.com/auskento/yahlp-templates/main/templates/yahlp-public-google.xml</TemplateURL>
  <Icon>https://raw.githubusercontent.com/auskento/yahlp/main/yahlp-150.png</Icon>
  <WebUI>https://yourdomain.com</WebUI>
  <PostArgs/>
  <CloudSync>false</CloudSync>
  <Description>yahlp - Public Mode with HTTPS and Google OAuth Authentication. Secure deployment with Google account login.</Description>
  <Overview>yahlp - Yet Another HomeLab Portal - Public Google OAuth Template&#13;&#13;This template is configured for public mode deployment with:&#13;- HTTPS access (ports 80 for HTTP redirect and 443 for HTTPS)&#13;- Google OAuth authentication (sign in with Google account)&#13;- Let's Encrypt SSL certificate (automatic renewal)&#13;- Domain-based access&#13;&#13;Requires: Google Cloud Console credentials, valid domain, email address, and Let's Encrypt certificate provisioning.</Overview>
  <Networking>
    <Mode>br0</Mode>
    <Publish>
      <Port>
        <HostPort>80</HostPort>
        <ContainerPort>80</ContainerPort>
        <Protocol>tcp</Protocol>
        <Description>HTTP</Description>
        <Access>External</Access>
      </Port>
      <Port>
        <HostPort>443</HostPort>
        <ContainerPort>443</ContainerPort>
        <Protocol>tcp</Protocol>
        <Description>HTTPS</Description>
        <Access>External</Access>
      </Port>
    </Publish>
  </Networking>
  <Data>
    <Volume>
      <HostDir>/mnt/user/appdata/yahlp-public-google/logs</HostDir>
      <ContainerDir>/var/log/apache2</ContainerDir>
      <Mode>rw</Mode>
      <Description>Apache Logs and Sites Config</Description>
      <Access>rw</Access>
      <Exclude/>
      <IsFileShare>false</IsFileShare>
    </Volume>
    <Volume>
      <HostDir>/mnt/user/appdata/yahlp-public-google/letsencrypt</HostDir>
      <ContainerDir>/etc/letsencrypt</ContainerDir>
      <Mode>rw</Mode>
      <Description>Let's Encrypt Certificates</Description>
      <Access>rw</Access>
      <Exclude/>
      <IsFileShare>false</IsFileShare>
    </Volume>
  </Data>

  <Environment>
    <!-- DEPLOYMENT & DOMAIN SETTINGS -->
    <Variable>
      <Name>ACCESS_MODE</Name>
      <Value>public</Value>
    </Variable>
    <Variable>
      <Name>DOMAIN</Name>
      <Value>yahlp.yourdomain.com</Value>
    </Variable>
    <Variable>
      <Name>EMAIL</Name>
      <Value>your-email@yourdomain.com</Value>
    </Variable>

    <!-- TIMEZONE & DASHBOARD CUSTOMIZATION -->
    <Variable>
      <Name>TZ</Name>
      <Value></Value>
    </Variable>

    <!-- DASHBOARD SETTINGS -->
    <Variable>
      <Name>DASH_STYLE</Name>
