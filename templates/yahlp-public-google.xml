    </Variable>
    <Variable>
      <Name>DASHBOARD_THEME</Name>
      <Value>dark</Value>
    </Variable>
    <Variable>
      <Name>DASHBOARD_LANDING</Name>
      <Value></Value>
    </Variable>
    <Variable>
      <Name>DASHBOARD_ORDER</Name>
      <Value>SAB,GET,HYD,TRA,QBI,DEL,SON,RAD,LID,WHI,PRO,SEE,BAZ,JEL,EMB,PLX,TAU,MNT</Value>
    </Variable>

    <!-- SITES CONFIGURATION -->
    <Variable>
      <Name>SITES_ENABLED</Name>
      <Value></Value>
    </Variable>

    <!-- AUTHENTICATION -->
