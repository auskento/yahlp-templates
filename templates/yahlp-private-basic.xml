<?xml version="1.0" encoding="utf-8"?>
<Container version="2">
  <Name>YAHLP-Private</Name>
  <Repository>auskento/yahlp</Repository>
  <Registry>https://hub.docker.com</Registry>
  <Network>bridge</Network>
  <MyIP/>
  <Shell>bash</Shell>
  <Privileged>false</Privileged>
  <Support>https://github.com/auskento/YAHLP</Support>
  <Project>https://github.com/auskento/YAHLP</Project>
  <Category>Network:Web</Category>
  <TemplateURL>https://raw.githubusercontent.com/auskento/yahlp-templates/main/templates/yahlp-private-basic.xml</TemplateURL>
  <Icon>https://raw.githubusercontent.com/auskento/YAHLP/main/html/icons/yahlp.png</Icon>
  <WebUI>http://[IP]:80/</WebUI>
  <CloudSync>false</CloudSync>
  <Description>YAHLP - Private Mode (HTTP + Basic Auth). Simple setup for internal networks with username/password protection. No domain or certificates required.</Description>
  <Overview>YAHLP - Yet Another HomeLab Portal - Private Mode Template

Configured for private network deployment with:
- HTTP access only (port 80)
- Basic authentication (username/password)
- Internal network access

Perfect for private lab environments without public exposure.</Overview>
  <Networking>
    <Mode>bridge</Mode>
    <Publish>
      <Port>
        <HostPort>80</HostPort>
        <ContainerPort>80</ContainerPort>
        <Protocol>tcp</Protocol>
        <Description>HTTP</Description>
        <Access>External</Access>
      </Port>
    </Publish>
  </Networking>
  <Data>
    <Volume>
      <HostDir>/mnt/user/appdata/yahlp/letsencrypt</HostDir>
      <ContainerDir>/etc/letsencrypt</ContainerDir>
      <Mode>rw</Mode>
      <Description>SSL Certificates</Description>
      <Access>rw</Access>
      <Exclude/>
      <IsFileShare>false</IsFileShare>
    </Volume>
    <Volume>
      <HostDir>/mnt/user/appdata/yahlp/config</HostDir>
      <ContainerDir>/etc/yahlp</ContainerDir>
      <Mode>rw</Mode>
      <Description>Configuration</Description>
      <Access>rw</Access>
      <Exclude/>
      <IsFileShare>false</IsFileShare>
    </Volume>
    <Volume>
      <HostDir>/mnt/user/appdata/yahlp/logs</HostDir>
      <ContainerDir>/var/log/apache2</ContainerDir>
      <Mode>rw</Mode>
      <Description>Apache Logs</Description>
      <Access>rw</Access>
      <Exclude/>
      <IsFileShare>false</IsFileShare>
    </Volume>
  </Data>

  <Environment>
    <Variable><Name>ACCESS_MODE</Name><Value>private</Value></Variable>
    <Variable><Name>IP</Name><Value></Value></Variable>
    <Variable><Name>DASHBOARD_NAME</Name><Value>YAHLP</Value></Variable>
    <Variable><Name>DASHBOARD_STYLE</Name><Value>modern</Value></Variable>
    <Variable><Name>DASHBOARD_COLOR</Name><Value>#00A99D</Value></Variable>
    <Variable><Name>AUTHTYPE</Name><Value>basic</Value></Variable>
    <Variable><Name>BASIC_AUTH_CREDENTIALS</Name><Value></Value></Variable>
    <Variable><Name>TZ</Name><Value>UTC</Value></Variable>
  </Environment>

  <Config Name="Access Mode" Target="ACCESS_MODE" Default="private" Mode="" Type="Variable" Display="advanced" Required="false" Mask="false"/>
  <Config Name="Internal IP" Target="IP" Default="" Mode="" Description="Your server IP (e.g., 192.168.1.100)" Type="Variable" Display="always" Required="true" Mask="false"/>
  <Config Name="Dashboard Name" Target="DASHBOARD_NAME" Default="YAHLP" Mode="" Type="Variable" Display="always" Required="false" Mask="false"/>
  <Config Name="Dashboard Layout" Target="DASHBOARD_STYLE" Default="modern" Mode="" Description="Choose: classic, modern, sleek, minimal" Type="Variable" Display="always" Required="false" Mask="false"/>
  <Config Name="Accent Color" Target="DASHBOARD_COLOR" Default="#00A99D" Mode="" Type="Variable" Display="always" Required="false" Mask="false"/>
  <Config Name="Authentication" Target="AUTHTYPE" Default="basic" Mode="" Type="Variable" Display="advanced" Required="false" Mask="false"/>
  <Config Name="Basic Auth Credentials" Target="BASIC_AUTH_CREDENTIALS" Default="" Mode="" Description="Format: user:pass or user1:pass1|user2:pass2" Type="Variable" Display="always" Required="true" Mask="true"/>
  <Config Name="Timezone" Target="TZ" Default="UTC" Mode="" Type="Variable" Display="advanced" Required="false" Mask="false"/>
</Container>
