    <Variable>
      <Name>ICON_URL_QBITTORRENT</Name>
      <Value></Value>
    </Variable>
    <Variable>
      <Name>ICON_URL_DELUGE</Name>
      <Value></Value>
    </Variable>
    <Variable>
      <Name>ICON_URL_JELLYFIN</Name>
      <Value></Value>
    </Variable>
    <Variable>
      <Name>ICON_URL_EMBY</Name>
      <Value></Value>
    </Variable>
    <Variable>
      <Name>ICON_URL_PLEX</Name>
      <Value></Value>
    </Variable>
    <Variable>
      <Name>ICON_URL_TAUTULLI</Name>
      <Value></Value>
    </Variable>
  </Environment>

  <Labels/>

  <Config Name="IP Address" Target="IP" Default="192.168.x.x" Mode="" Description="Container IP address on your network (REQUIRED for private mode)" Type="Variable" Display="always" Required="true" Mask="false"/>
  <Config Name="Timezone" Target="TZ" Default="Australia/Melbourne" Mode="" Description="Timezone" Type="Variable" Display="always" Required="false" Mask="false"/>
  <Config Name="Dashboard Style" Target="STYLE" Default="sleek" Mode="" Description="Dashboard style: classic, modern, sleek, or minimal" Type="Variable" Display="always" Required="false" Mask="false"/>
  <Config Name="Dashboard Name" Target="DASHBOARD_NAME" Default="Media Server" Mode="" Description="Custom dashboard title shown in header" Type="Variable" Display="always" Required="false" Mask="false"/>
  <Config Name="Dashboard Icon" Target="DASHBOARD_ICON" Default="/icons/homelabportal.png" Mode="" Description="Dashboard icon path (place custom icons in html/icons directory)" Type="Variable" Display="always" Required="false" Mask="false"/>
  <Config Name="Dashboard Landing" Target="DASHBOARD_LANDING" Default="" Mode="" Description="Default iframe page (examples: radarr, sonarr/calendar). Leave blank for welcome screen" Type="Variable" Display="always" Required="false" Mask="false"/>
  <Config Name="Dashboard Theme" Target="DASHBOARD_THEME" Default="dark" Mode="" Description="Dashboard theme: dark or light" Type="Variable" Display="always" Required="false" Mask="false"/>
  <Config Name="Dashboard Order" Target="DASHBOARD_ORDER" Default="CONTENT,SEARCH,USENET,TORRENTS,MEDIA" Mode="" Description="Service group display order" Type="Variable" Display="always" Required="false" Mask="false"/>

  <Config Name="Basic Auth Credentials" Target="BASIC_AUTH_CREDENTIALS" Default="user:password" Mode="" Description="Format: user:pass|user2:pass2 (pipe-separated for multiple users)" Type="Variable" Display="always" Required="true" Mask="true"/>

  <!-- USENET Services -->
