      <Name>ENABLE_RADARR</Name>
      <Value>false</Value>
    </Variable>
    <Variable>
      <Name>RADARR_URL</Name>
      <Value>http://YOUR_BACKEND_HOST:7878</Value>
    </Variable>
    <Variable>
