      <Value>http://YOUR_BACKEND_HOST:8096</Value>
    </Variable>
    <Variable>
      <Name>ENABLE_PLEX</Name>
      <Value>false</Value>
    </Variable>
    <Variable>
      <Name>PLEX_URL</Name>
      <Value>http://YOUR_BACKEND_HOST:32400</Value>
    </Variable>
    <Variable>
      <Name>ENABLE_JELLYFIN</Name>
      <Value>false</Value>
    </Variable>
    <Variable>
      <Name>JELLYFIN_URL</Name>
      <Value>http://YOUR_BACKEND_HOST:8096</Value>
    </Variable>
    <Variable>
      <Name>ENABLE_TAUTULLI</Name>
      <Value>false</Value>
    </Variable>
    <Variable>
      <Name>TAUTULLI_URL</Name>
      <Value>http://YOUR_BACKEND_HOST:8181</Value>
    </Variable>
    <!-- Service Icon URLs (for advanced view) -->
    <Variable>
      <Name>ICON_URL_SONARR</Name>
      <Value></Value>
    </Variable>
    <Variable>
      <Name>ICON_URL_RADARR</Name>
      <Value></Value>
    </Variable>
    <Variable>
      <Name>ICON_URL_WHISPARR</Name>
      <Value></Value>
    </Variable>
    <Variable>
      <Name>ICON_URL_LIDARR</Name>
      <Value></Value>
    </Variable>
    <Variable>
      <Name>ICON_URL_PROWLARR</Name>
      <Value></Value>
    </Variable>
    <Variable>
      <Name>ICON_URL_SEERR</Name>
      <Value></Value>
    </Variable>
    <Variable>
      <Name>ICON_URL_BAZARR</Name>
      <Value></Value>
    </Variable>
    <Variable>
      <Name>ICON_URL_SABNZBD</Name>
      <Value></Value>
    </Variable>
    <Variable>
      <Name>ICON_URL_NZBGET</Name>
      <Value></Value>
    </Variable>
    <Variable>
      <Name>ICON_URL_NZBHYDRA</Name>
      <Value></Value>
