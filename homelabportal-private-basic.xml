    <Variable>
      <Name>ENABLE_WHISPARR</Name>
      <Value>false</Value>
    </Variable>
    <Variable>
      <Name>WHISPARR_URL</Name>
      <Value>http://YOUR_BACKEND_HOST:6969</Value>
    </Variable>
    <!-- SEARCH Services -->
    <Variable>
      <Name>ENABLE_PROWLARR</Name>
      <Value>false</Value>
    </Variable>
    <Variable>
      <Name>PROWLARR_URL</Name>
      <Value>http://YOUR_BACKEND_HOST:9696</Value>
    </Variable>
    <Variable>
      <Name>ENABLE_SEERR</Name>
      <Value>false</Value>
    </Variable>
    <Variable>
      <Name>SEERR_URL</Name>
      <Value>http://YOUR_BACKEND_HOST:5055</Value>
    </Variable>
    <Variable>
      <Name>ENABLE_BAZARR</Name>
      <Value>false</Value>
